# Required
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (all default to Sonnet except Evaluator=Haiku — see config.py)
# Uncomment ONLY for your final showcase run (Phase 6):
# ORCHESTRATOR_MODEL=claude-opus-4-6

# Optional: LangSmith tracing (recommended for debugging)
# Get your API key at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=self-evolving-codegen
